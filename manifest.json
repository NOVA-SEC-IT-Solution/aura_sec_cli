{
  "version": "1.0",
  "roles": [
    {
      "name": "Backend",
      "display_name": "Backend Service",
      "markers": ["Cargo.toml", "go.mod", "pom.xml"],
      "quality_command": "cargo check --message-format=json",
      "checklist_path": "templates/backend.md"
    },
    {
      "name": "Frontend",
      "display_name": "Frontend Application",
      "markers": ["package.json", "tsconfig.json"],
      "quality_command": "npx tsc --noEmit",
      "checklist_path": "templates/frontend.md"
    },
    {
      "name": "Infrastructure",
      "display_name": "Infrastructure (Terraform)",
      "markers": ["terraform.tf", "main.tf", "Dockerfile"],
      "quality_command": "terraform validate -json",
      "checklist_path": "templates/infra.md"
    }
  ],
  "secret_patterns": [
    {
      "name": "AWS Access Key",
      "regex": "(?i)AKIA[0-9A-Z]{16}",
      "severity": "Critical"
    },
    {
      "name": "RSA Private Key",
      "regex": "-----BEGIN (RSA )?PRIVATE KEY-----",
      "severity": "Critical"
    },
    {
      "name": "Generic Password/Token",
      "regex": "(?i)(password|secret|token|api_key|apikey)[\\s:=]*[\"'][\\w\\-]{16,}[\"']",
      "severity": "High"
    },
    {
      "name": "GitHub Token",
      "regex": "ghp_[a-zA-Z0-9]{36}",
      "severity": "Critical"
    },
    {
      "name": "Slack Token",
      "regex": "xox[baprs]-[0-9]+-[0-9]+-[a-zA-Z0-9]+",
      "severity": "Critical"
    },
    {
      "name": "Stripe Secret Key",
      "regex": "sk_live_[0-9a-zA-Z]{24}",
      "severity": "Critical"
    },
    {
      "name": "Database Connection String",
      "regex": "(?i)(postgres|mysql)://[^\\s]+:[^\\s]+@[^\\s]+",
      "severity": "Critical"
    }
  ]
}
